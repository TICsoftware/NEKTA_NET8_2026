<header class="w-full fixed top-0 left-0 z-999 transition-all duration-500" id="mainHeader">

    <!-- TOP STRIP -->
    <div class="bg-[#e9e9e9] header-top-nav">
        <div class="container">
            <div class="py-2 flex items-center justify-center lg:justify-between">
                <div class="flex items-center gap-2 hidden lg:block header-logo">
                    <a href="/"> <img src="/Assets/images/logo/cop-logo.svg" class="mx-w-[150px] sm:max-w-max" alt="cop logo" /></a>
                </div>


                <div class="top-wrap-outer">
                    <div class="text-base">A unit of Tata Cancer Care Foundation</div>
                    
                    <div class="top-wrap-block">
                        <div class="search-header-wrap search-open-btn cursor-pointer"> <img src="/Assets/images/common-images/search-icon.svg" class="w-auto" alt="search icon" /></div>
                        <!-- Search Overlay -->
                        <div class="search-overlay">
                            <div class="search-box-wrap">

                                <!-- Search Form -->
                                <form class="search-form">

                                    <input id="txtSearch"
                                        type="text"
                                        placeholder="Search tests, services..."
                                        class="search-input"
                                    />

                                    <button type="submit" class="search-submit-btn" id="btnSearchHeader">
                                        Search
                                    </button>

                                </form>

                                <!-- Close -->
                                <button class="search-close-btn">
                                    ✕
                                </button>

                            </div>
                        </div>

                        <!-- DARK MODE -->
                        <div class="darkmode-wrap relative z-10 flex items-center pl-3">
                            <button id="themeToggle" type="button" aria-label="Toggle dark mode"
                                    class="relative w-9 h-9 rounded-full touch-manipulation bg-black/10 backdrop-blur-md flex items-center justify-center border border-black/20 hover:bg-black/20 transition-all duration-300">
                                <svg id="sunIcon" class="theme-icon absolute w-5 h-5 text-black-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="4" />
                                    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
                                </svg>
                                <svg id="moonIcon" class="theme-icon absolute w-5 h-5 text-blue-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                </div>

                <!-- ✅ DESKTOP SCROLL HAMBURGER -->
                <div class="scroll-hamburger-desktop">
                    <button id="scrollHamburgerDesktop" class="hamburger-btn-desktop" aria-label="Name">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- MAIN NAV -->
    <div class="relative bg-black text-white custom-skew header-bottom-nav">
        <div class="container">
            <div class="flex items-center py-2 lg:py-0 gap-5 lg:gap-0 justify-start lg:justify-between">
                <div class="flex items-center gap-2 lg:hidden">
                    <a href="/"><img src="/Assets/images/logo/cop-white-logo.svg" class="max-w-40 sm:max-w-32.5" alt="cop logo" /> </a>
                </div>

                <!-- LEFT NAV -->
                <div class="flex-1 hidden lg:block">
                    <nav id="desktopNav" class="flex items-center gap-5 sm:gap-4 md:gap-4 2xl:gap-6 text-sm font-medium relative desktopNav-wrap">

                        <div class="relative group">
                            <a href="/tests-and-services" class="relative group text-white hover:text-white py-5 transition-all duration-300 h-link">
                                Tests & Services
                                <span class="absolute left-1/2 bottom-0 w-0 h-1.25 bg-primary rounded-t-md -translate-x-1/2 transition-all duration-300 ease-out group-hover:w-7"></span>
                            </a>
                        </div>

                        <div class="relative nav-item group">
                            <a href="/clinical-expertise/Our-team" class="relative group text-white hover:text-white py-5 transition-all duration-300 h-link">
                                Clinical Expertise
                                <span class="absolute left-1/2 bottom-0 w-0 h-1.25 bg-primary rounded-t-md -translate-x-1/2 transition-all duration-300 ease-out group-hover:w-7"></span>
                            </a>
                            <div class="nav-dropdown absolute left-1/2 -translate-x-1/2 top-[120%] pt-4 z-50 opacity-0 invisible">
                                <div class="bg-white text-black rounded-xl shadow-2xl px-4 py-4 min-w-65">
                                    <div class="flex flex-col gap-3 text-sm">
                                        <a href="/clinical-expertise/Our-team" class="hover:text-primary transition">Our Team</a>
                                             <a href="/clinical-expertise/case-consults" class="hover:text-primary transition">Case Consults</a>
                                      

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="relative nav-item group">
                            <a href="/academy-and-research/Dr-anita-borges" class="relative group text-white hover:text-white py-5 transition-all duration-300 h-link">
                                Academy & Research
                                <span class="absolute left-1/2 bottom-0 w-0 h-1.25 bg-primary rounded-t-md -translate-x-1/2 transition-all duration-300 ease-out group-hover:w-7"></span>
                            </a>
                            <div class="nav-dropdown absolute left-1/2 -translate-x-1/2 top-[120%] pt-4 z-50 opacity-0 invisible">
                                <div class="bg-white text-black rounded-xl shadow-2xl px-4 py-4 min-w-65">
                                    <div class="flex flex-col gap-3 text-sm">
                                        <a href="/academy-and-research/Dr-anita-borges" class="hover:text-primary transition">Dr Anita Borges</a>
                                          <a href="/academy-and-research/publications-and-resources" class="hover:text-primary transition">Publications & Resources</a>
                                           <a href="/academy-and-research/events-and-cme" class="hover:text-primary transition">Events & CME</a>
                                            <a href="/academy-and-research/fellowships-and-training" class="hover:text-primary transition">Fellowships & Training</a>
                                         
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="relative group">
                            <a href="/for-patients" class="relative group text-white hover:text-white py-5 transition-all duration-300 h-link">
                                For Patients
                                <span class="absolute left-1/2 bottom-0 w-0 h-1.25 bg-primary rounded-t-md -translate-x-1/2 transition-all duration-300 ease-out group-hover:w-7"></span>
                            </a>
                        </div>

                        <div class="relative nav-item group">
                            <a href="/about-cop" class="relative group text-white hover:text-white py-5 transition-all duration-300 h-link">
                                About COP
                                <span class="absolute left-1/2 bottom-0 w-0 h-1.25 bg-primary rounded-t-md -translate-x-1/2 transition-all duration-300 ease-out group-hover:w-7"></span>
                            </a>
                                <div class="nav-dropdown absolute left-1/2 -translate-x-1/2 top-[120%] pt-4 z-50 opacity-0 invisible">
                                    <div class="bg-white text-black rounded-xl shadow-2xl px-4 py-4 min-w-65">
                                        <div class="flex flex-col gap-3 text-sm">
                                            <a href="/about-cop" class="hover:text-primary transition lg:hidden">Overview</a>
                                            <a href="/about-cop/updates" class="hover:text-primary transition">Updates</a>
                                            <a href="/about-cop/careers" class="hover:text-primary transition">Careers</a>
                                        </div>
                                    </div>
                                </div>
                        </div>

                        <div class="relative group">
                            <a href="/contactus" class="relative group text-white hover:text-white py-5 transition-all duration-300 h-link">
                                Contact
                                <span class="absolute left-1/2 bottom-0 w-0 h-1.25 bg-primary rounded-t-md -translate-x-1/2 transition-all duration-300 ease-out group-hover:w-7"></span>
                            </a>
                        </div>

                    </nav>
                </div>

                <!-- RIGHT RED ANGLED SECTION (Desktop) -->
                <div id="desktopCta" class="relative px-0 pt-3 pb-2 items-center gap-3 bg-primary hidden lg:flex desktopCta-wrap">
                    <div class="absolute -left-10 top-0 w-[175%] h-17 bg-primary skew-x-[-25deg] skew-bar"></div>
                    <a href="https://himstccf.org/WEBPatientPortal/CompanyPortal/CompanyLandingPage" target="_blank" class="themeht-btn white-btn">Book a Test</a>
                    <div class="themeht-btn white-outline-btn data-trigger cursor-pointer" data-id="secondopinion" data-trigger="modal" data-target="#secondOpinionPopup">Second Opinion</div>
                    <a href="/test-directory" class="themeht-btn white-outline-btn">Explore Tests</a>
                </div>
                

                <!-- MOBILE: Hamburger only -->
                <div class="flex items-center px-2 py-3 lg:hidden">
                    <button id="hamburgerBtn" class="hamburger-btn" aria-label="Open menu" aria-expanded="false">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- OVERLAY -->
    <div id="mobileOverlay" class="mobile-overlay"></div>

    <!-- MOBILE DRAWER — shell only, JS builds content -->
    <nav id="mobileDrawer" class="mobile-drawer" aria-hidden="true">
        <div class="mobile-drawer-header">
            <button id="drawerClose" class="drawer-close" aria-label="Close menu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M18 6L6 18M6 6l12 12" />
                </svg>
            </button>
        </div>
        <ul id="mobileNavList" class="mobile-nav-list"></ul>
        <div id="mobileCtaGroup" class="mobile-cta-group"></div>
    </nav>

</header>

