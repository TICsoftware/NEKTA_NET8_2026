@model ContactUs

<div>
    <div class="title-heading-outer-center pb-5 sm:pb-5 w-full">

        @if (Model.form_type == "submitcase")
        {
            <h3 class="text-20 title-heading-anim ">
                Submit a <span class="highlight-span"> case </span>
            </h3>
        }
        else
        {
            <h3 class="text-20 title-heading-anim ">
                Second <span class="highlight-span"> Opinion </span>
            </h3>
        }

    </div>
    <p>
        Share your details and our specialists will review your case and guide you with the best possible treatment
        options.
    </p>

 
    @using (Html.BeginForm("Medicalenquiry", "Connect", FormMethod.Post, new
    {
        id = "frmMedicalenquiry",
        enctype = "multipart/form-data",
        @class = "space-y-4 grid grid-cols-1 sm:grid-cols-2 gap-4"
    }))
    {
        if(ViewBag.SuccessMessage != null)
        {

            <div id="showMessage" tabindex="0"
                class="hidden mt-6 p-3 rounded-xl bg-green-50 border border-green-200 flex items-start gap-3 sm:col-span-2">
                @if(ViewBag.SuccessMessage != null && !string.IsNullOrWhiteSpace(ViewBag.SuccessMessage))
            { 
                <!-- Icon -->
                <div class="flex-shrink-0 w-6 h-6 flex items-center justify-center rounded-full bg-green-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                </div>

                <!-- Text -->
                <div id="divthankyoumsg" tabindex="0">
                    <p class="text-sm! font-medium text-green-800">
                        @Html.Raw(ViewBag.SuccessMessage)
                    </p>
                </div>
            }
 
            </div>
        }
       

        @Html.AntiForgeryToken()
        <div  id="divvalidation"  class="sm:col-span-2">
         @Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
        </div>
        <!-- Row 1 -->
        
        
        <div>
            <label class="block text-sm font-medium mb-1">Full Name <span class="text-red-500">*</span></label>
            @Html.TextBoxFor(model => model.FullName, new { id = "FullName", @class = "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary",
                @placeholder = "Enter your name" })
            @Html.ValidationMessageFor(model => model.FullName)
        </div>
        <div>
            <label class="block text-sm font-medium mb-1">Contact Number <span class="text-red-500">*</span></label>
            @Html.TextBoxFor(model => model.Contact, new { id = "Contact", 
            @class = "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary",
                        @placeholder = "Enter your contact number" })
            @Html.ValidationMessageFor(model => model.Contact)
        </div>
        <div>
            <label class="text-sm font-medium">Email ID <span class="text-red-500">*</span></label>
            @Html.TextBoxFor(model => model.Email, new { id="Email" , 
            @class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary",
                        @placeholder = "Enter your email"})
            @Html.ValidationMessageFor(model => model.Email)
        </div>

        <div>
            <label class="text-sm font-medium block mb-1">Patient Clinical History Record <span class="text-muted">(optional)</span></label>
            <label for="attachment"
                class="flex items-center gap-3 px-6 py-2 border border-gray-300 rounded-xl cursor-pointer bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-400 transition-all duration-300 dark-bglight upload-doc-btn">
                <img src="Assets/images/common-images/choose-icon.svg" class="object-cover block " />
                @* <span id="fileText" class="text-base text-[#8f8f8f] font-[300] dark-textwhite">Upload Document </span> *@
                <input type="file" id="attachment" name="attachment" class="text-xs text-[#8f8f8f] font-[300] dark-textwhite" />                
                @if (!string.IsNullOrEmpty(Model?.TempFileName))
                {
                     <span class="text-green-600 ml-2">File already selected ✔</span>
                }

            </label>
            @Html.ValidationMessageFor(model => model.attachment)
        </div>


        <div class="sm:col-span-2">
            <label class="text-sm font-medium">Message <span class="text-red-500">*</span></label>
            @Html.TextAreaFor(model => model.Message, new { @class = "mt-1 w-full rounded-xl border border-[#E9E9E9] px-4 py-3 focus:outline-none focus:ring-2 focus:ring-red-400", @rows = "4",
            @placeholder = "Please share your query or message here..." })
             @Html.ValidationMessageFor(model => model.Message)
        </div>
        <div class="sm:col-span-2">
        <div class="input-field col s12 p-0 mr-3.75 flex flex-col sm:flex-row items-start sm:items-center gap-2">
            <div class="g-recaptcha" data-sitekey="@ViewBag.captchapublickey" ></div>
            <div class="text-[#716868] font-light italic dark-textwhite text-sm">
                (Cannot view the captcha? Please make sure Google <br />
                and its services are enabled on your system.)
            </div>
        </div>
    </div>

        <p class="text-muted text-small lg:max-w-full sm:col-span-2">
            By submitting this form, you expressly consent to the Centre for Oncopathology collecting, storing, 
            and processing the information provided by you, and to contacting you in connection with your enquiry.
        </p>
   
    <!-- Button -->
    <div class="text-center sm:col-span-2">
        <button id="submitformBtn" type="submit" class="w-auto themeht-btn color-btn darkwhite-btn">
            Submit Request 
        </button>
    </div>
    @Html.HiddenFor(model => model.form_type)
    @Html.HiddenFor(model => model.TempFileName)
    <input type="hidden" id="strstatus_subform" name="strstatus_subform" value="@(ViewBag.SuccessMessage == null ? "false" :"true")" />
    <span class="btn-loader"></span>
        
}
 
</div>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>  