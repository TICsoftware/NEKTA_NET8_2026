@using Nekta_BusinessLogic.Entity
@model TestDirectory

<div
    class="fade-2 mx-auto w-[92vw] max-w-[min(92vw,900px)] sm:max-w-[min(85vw,900px)]  md:max-w-[min(80vw,900px)] lg:max-w-[min(75vw,900px)] xl:max-w-[min(75vw,900px)] bg-white rounded-2xl shadow-xl px-5 sm:px-8 py-10 mt-10 dark-bgblack">

    <h2 class="text-24 font-noraml mb-5 dark-textwhite">Test Finder</h2>

    <!-- Search bar -->
    <div
        class="flex flex-col sm:flex-row items-stretch sm:items-center border border-gray-200 rounded-xl overflow-hidden focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/10 transition-all">

        <!-- Input + Icon Wrapper -->
        <div class="flex items-center flex-1 px-3">

            <span class="pr-2 flex items-center shrink-0 text-gray-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </span>

            <input type="text" id="Title" placeholder="Search by test name, biomarker, or cancer type…"
                class="w-full py-3 text-sm placeholder-[#767676] outline-none bg-transparent font-body" />
        </div>


    </div>

    <!-- Filters -->
    <div class="flex flex-col sm:flex-row flex-wrap gap-3 mt-4">

        <div class="fy-select-inner relative flex-1 min-w-[140px]">
            <select id="ddSpecimen"
                class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                @foreach (var item in Model.Specimen)
                {
                    <option value="@item.id">@item.title</option>
                }
            </select>
        </div>

        <div class="fy-select-inner relative flex-1 min-w-[140px]">
            <select id="ddTypeTest"
                class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                @foreach (var item in Model.TypeTest)
                {
                    <option value="@item.id">@item.title</option>
                }
            </select>
        </div>

        <div class="fy-select-inner relative flex-1 min-w-[140px]">
            <select id="ddOrgan"
                class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                @foreach (var item in Model.Organ)
                {
                    <option value="@item.id">@item.title</option>
                }
            </select>
        </div>

        <div class="fy-select-inner relative flex-1 min-w-[140px]">
            <select id="ddDepartment"
                class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                @foreach (var item in Model.Department)
                {
                    <option value="@item.id">@item.title</option>
                }
            </select>
        </div>

    </div>

    <!-- Explore button -->
    <button id="btnSearchRedirect" class="mt-5 themeht-btn color-btn darkwhite-btn"> Search </button>

</div>



