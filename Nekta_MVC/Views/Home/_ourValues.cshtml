@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model List<HomeCommonModel>


@{
    var Component = Model
    .Where(x => x.IsBlock == 0)
    .OrderBy(x => x.Sequence)
    .FirstOrDefault();
}

</div>
</section>
<section class="section-pb values-section animate-section relative">
    <div class="hexagon-big floating-icon">
        <img src="/Assets/images/common-images/hexagon-vector-big.svg" class="w-auto" alt="">
    </div>
    <div class="container">
        <div class="values-wrapper flex flex-col lg:flex-row items-start gap-10 relative">

            <!-- IMAGE -->
            <div class="values-image w-full lg:w-1/2 flex justify-center rounded-2xl">
                <div class="img-box w-full lg:w-full rounded-2xl overflow-hidden">
                    <img src="@Component.ComponentThumbnail" alt="@Component.ComponentThumbnailAltText"
                        class="w-full h-full object-cover rounded-2xl" />
                </div>
            </div>

            <!-- TEXT -->
            <div class="values-text w-full lg:w-1/2 lg:opacity-0 lg:translate-y-0 title-heading-outer">
                @* <h2 class="text-h2 title-heading-anim">
                            @Html.Raw(Component.DisplayTitle.CleanParagraphTags())
                        </h2> *@
                <div class="vm-outer space-y-5">
                    @if (!string.IsNullOrEmpty(Component.Intro))
                    {
                        @Html.Raw(Component.Intro)
                    }
                </div>
            </div>

        </div>
    </div>
    <div class="container">
        <div
            class="grid grid-cols-2 sm:grid-cols-4 items-center justify-center text-center gap-y-6 lg:gap-y-0 divide-y-0 md:divide-y-0 md:divide-x lg:divide-y-0 lg:divide-x md:divide-primary mt-12 reveal-group value-list">
            <!-- ITEM 1 -->
            @foreach (var item in Model.Where(x => x.IsBlock == 1).OrderBy(x => x.Sequence))
            {
                <div class="px-1 sm:px-4 py-0 w-full md:w-auto reveal-item">
                    <div class="value-item flex items-center justify-center gap-3 icon-transform-item">
                        <div class="icon-wrap icon-transform">
                            <img src="@item.ThumbnailImage" class="w-auto icon-draw" alt="@item.ThumbnailAltText">
                        </div>
                        <span class="text-20 font-semibold">@item.Title</span>
                    </div>
                </div>
            }
        </div>

    </div>
</section>