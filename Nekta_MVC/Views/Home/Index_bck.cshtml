            </div>

            <!-- Card 2 -->
            <div
                class="px-0 md:px-6 lg:px-8 py-6 flex flex-col gap-3 card-divider items-start team-item-box reveal-item icon-transform-item">
                <div class="card-icon mb-2 icon-transform">
                    <img src="/Assets/images/homepage/treatment-decisions/advanced-biomarkers.svg" class="" alt="" />
                </div>
                <h3 class="font-semibold text-20 leading-snug">
                    Advanced biomarkers<br />&amp; molecular testing
                </h3>
                <a class="themeht-btn color-btn arrow-btn" data-trigger="modal" data-target="#biomarkerPopup"> Learn
                    More <img src="/Assets/images/common-images/btn-arrow-white.svg" alt="arrow icon"> </a>
            </div>

            <!-- Card 3 -->
            <div
                class="px-0 md:px-6 lg:px-8 py-6 flex flex-col gap-3 card-divider items-start team-item-box reveal-item icon-transform-item">
                <div class="card-icon mb-2 icon-transform">
                    <img src="/Assets/images/homepage/treatment-decisions/second-opinions.svg" class="" alt="" />
                </div>
                <h3 class="font-semibold text-20 leading-snug">
                    Second<br />opinions
                </h3>
                <a class="themeht-btn color-btn arrow-btn data-trigger" data-trigger="modal"
                    data-target="#secondOpinionDiagnosisPopup"> Learn More <img
                        src="/Assets/images/common-images/btn-arrow-white.svg" alt="arrow icon"> </a>
            </div>

            <!-- Card 4 -->
            <div
                class="px-0 md:px-6 lg:px-8 py-6 flex flex-col gap-3 card-divider items-start team-item-box reveal-item icon-transform-item">
                <div class="card-icon mb-2 icon-transform">
                    <img src="/Assets/images/homepage/treatment-decisions/education-training-leadership.svg" class=""
                        alt="" />
                </div>
                <h3 class="font-semibold text-20 leading-snug">
                    Education &amp; training<br />leadership
