                @* <a href="#" class="themeht-btn color-btn arrow-btn">  Learn More  <img src="/Assets/images/common-images/btn-arrow-white.svg" alt="arrow icon"> </a> *@

            </div>

        </div>

    </div>
</section>

@* FIND TEST SECTION *@
<section class="relative section-pb">
    <div class="relative overflow-hidden flex items-center justify-center min-h-[420px]">

        <img src="/Assets/images/homepage/find-test-bg.webp" alt=""
            class="absolute inset-0 w-full h-full object-cover -z-1 find-test-bg dark-grayscaleinvert0" />


        <div class=" absolute left-0 bottom-0 floating-icon"><img src="/Assets/images/common-images/hexagon-sm.svg"
                alt="" class="object-cover dark-grayscaleinvert0" /></div>
    </div>
    <div class="relative find-text-inner">
        <div class="hexagon-img">
            <div class="bt_bb_image bt_bb_shape_hexagon bt_bb_hover_style_zoom-in">
                <div class="bt_bb_image_content">
                    <img src="/Assets/images/homepage/test-img.webp" alt="">
                </div>
            </div>
        </div>

        <div class="relative z-10 -mt-100 find-test-outer">
            <div class="container">
                <div class="wrapper-title-outer">
                    <div class="wrapper-title title-heading-outer title-heading-outer-center pt-0 pb-5 sm:pb-10 filldark-title-heading-anim">
                        <h2 class="text-h2 title-heading-anim title-heading-anim-white">
                            Find Your Test </h2>
                    </div>
                </div>
            </div>
            <!-- ── Card ── -->
            <div
                class="fade-2 mx-auto w-[92vw] max-w-[min(92vw,900px)] sm:max-w-[min(85vw,900px)]           md:max-w-[min(80vw,900px)] lg:max-w-[min(75vw,900px)] xl:max-w-[min(75vw,900px)] bg-white rounded-2xl shadow-xl px-5 sm:px-8 py-10 mt-10 dark-bgblack">

                <h2 class="text-24 font-noraml mb-5 dark-textwhite">Test Finder</h2>

                <!-- Search bar -->
                <div
                    class="flex flex-col sm:flex-row items-stretch sm:items-center border border-gray-200 rounded-xl overflow-hidden focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/10 transition-all">

                    <!-- Input + Icon Wrapper -->
                    <div class="flex items-center flex-1 px-3">

                        <span class="pr-2 flex items-center shrink-0 text-gray-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                        </span>

                        <input type="text" placeholder="Search by test name, biomarker, or cancer type…"
                            class="w-full py-3 text-sm placeholder-[#767676] outline-none bg-transparent font-body" />
                    </div>


                </div>

                <!-- Filters -->
                <div class="flex flex-col sm:flex-row flex-wrap gap-3 mt-4">

                    <div class="fy-select-inner relative flex-1 min-w-[140px]">
                        <select
                            class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                            <option value="" disabled selected>Specimen</option>
                            <option>Specimen</option>
                            <option>Lung</option>
                            <option>Colorectal</option>
                            <option>Prostate</option>
                            <option>Ovarian</option>
                        </select>
                    </div>

                    <div class="fy-select-inner relative flex-1 min-w-[140px]">
                        <select
                            class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                            <option value="" disabled selected>Type of Test</option>
                            <option>Liquid Biopsy</option>
                            <option>Tissue Biopsy</option>
                            <option>Imaging</option>
                            <option>Molecular</option>
                        </select>
                    </div>

                    <div class="fy-select-inner relative flex-1 min-w-[140px]">
                        <select
                            class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                            <option value="" disabled selected>Organ</option>
                            <option>BRCA1/2</option>
                            <option>HER2</option>
                            <option>EGFR</option>
                            <option>PD-L1</option>
                            <option>MSI</option>
                        </select>
                    </div>

                    <div class="fy-select-inner relative flex-1 min-w-[140px]">
                        <select
                            class="w-full appearance-none border border-[#E9E9E9] rounded-xl px-4 py-2.5 pr-4 text-sm text-[#767676] bg-white focus:outline-none focus:border-brand cursor-pointer font-body transition-colors fy-select">
                            <option value="" disabled selected>Deparrtment</option>
                            <option>BRCA1/2</option>
                            <option>HER2</option>
                            <option>EGFR</option>
                            <option>PD-L1</option>
                            <option>MSI</option>
                        </select>
                    </div>

                </div>

                <!-- Explore button -->
                <button class="mt-5 themeht-btn color-btn darkwhite-btn"> Search </button>

            </div>
        </div>

        <!-- Tagline -->
        <div class="tagline-outer">
            <p class="text-center tagline mt-8 dark-textwhite"> While speed matters, accuracy is paramount.</p>
        </div>
    </div>
</section>



