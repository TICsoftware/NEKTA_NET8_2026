        <svg viewBox="0 0 1600 200" class="line-svg">
            <path id="linePath02" class="linePath"
                d="M1609.7 158.802C1672.53 -30.8498 1572.81 227.972 1436.75 231.919C1375.92 233.683 1341.49 210.656 1298.73 172.764C1260.67 139.044 1218.3 102.174 1173.56 78.0095C1052.61 12.6785 780.533 -83.7248 470.405 145.254C458.562 153.999 445.875 162.01 432.641 168.457C297.789 234.152 98.6833 328.006 -0.282471 7.02375"
                fill="none" stroke="#DE392E" stroke-width="1.00225" />

            <circle class="dot dot1" r="6" cx="0" cy="0" fill="#DE392E"></circle>
            <circle class="dot dot2" r="6" cx="0" cy="0" fill="#DE392E"></circle>

        </svg>
    </div>

    <div class="curve-bg-wrapper">
        <img src="/Assets/images/homepage/treatment-decisions-vector.svg" alt="" />
    </div>
    <div class="container">
        <div class="wrapper-title-outer">
            <div class="wrapper-title title-heading-outer title-heading-outer-center pb-5 sm:pb-10">
                <h2 class="text-h2 title-heading-anim">
                    Precision in cancer diagnosis <span class="highlight-span"> changes </span> </br> <span
                        class="highlight-span"> treatment decisions </span>
                </h2>
