@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/css/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/Assets/css/homepage-style.css" />
    <link rel="stylesheet" href="~/Assets/css/swiper-custom.css" />
}



<section class="relative overflow-hidden hero-section">
    <div class="hero-grid max-h-[630px]">
        <!-- ================= LEFT ================= -->
        <div class="relative w-full overflow-hidden h-[630px]">
            <div class="hero-vid-wrap">
                <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover" poster="">
                    <source src="/Assets/images/homepage/banner/video.mp4" type="video/mp4">
                </video>
                <!-- 🔲 Dark Overlay (for readability) -->
                <div class="absolute inset-0 bg-white/55"></div>
            </div>
            <div class="container">
                <div class="relative z-10 max-w-xl herobanner-content-wrapper py-8">

                    <h1 class="text-h1-home font-medium h1-title-heading-anim">
                        Centre for <br />
                        <span class="highlight-span">Oncopathology</span>
                    </h1>

                    <h2 class="mt-4 text-24 font-normal leading-snug"> India's specialist oncopathology reference lab,
                        built for diagnostic certainty</h2>

                    <p class="mt-2 text-base"> A unit of Tata Cancer Care Foundation</p>

                    <!-- HEX GRID -->
                    <div class="flex flex-wrap gap-4 mt-4 sm:mt-8">

                        <!-- HEX -->
                        <div
                            class="relative z-10 flex flex-wrap md:flex-nowrap justify-center md:justify-start gap-4 herosection-hex-outer">

                            <!-- HEX 1 -->
                            <div class="hex-wrap">
                                <svg viewBox="0 0 200 180" class="hex-svg">
                                    <polygon points="50,5 150,5 195,90 150,175 50,175 5,90" fill="white"
                                        stroke="#e5e7eb" stroke-width="1" />
                                </svg>
                                <div class="hex-content">
                                    <div class="text-red-500 mb-2">
                                        <img src="/Assets/images/homepage/banner/advanced-diagnostics-icon.svg"
                                            alt="" />
                                    </div>
                                    <p>Advanced<br />Diagnostics</p>
                                </div>
                            </div>

                            <!-- HEX 2 -->
                            <div class="hex-wrap">
                                <svg viewBox="0 0 200 180" class="hex-svg">
                                    <polygon points="50,5 150,5 195,90 150,175 50,175 5,90" fill="white"
                                        stroke="#e5e7eb" />
                                </svg>
                                <div class="hex-content">
                                    <div class="text-red-500 mb-2">
                                        <img src="/Assets/images/homepage/banner/tata-legacy-icon.svg" alt="" />
                                    </div>
                                    <p>Tata Legacy</p>
                                </div>
                            </div>

                            <!-- CENTER HEX -->
                            <div class="hex-wrap">
                                <svg viewBox="0 0 200 180" class="hex-svg">
                                    <polygon points="50,5 150,5 195,90 150,175 50,175 5,90" fill="white"
                                        stroke="#e5e7eb" />
                                </svg>
                                <div class="hex-content">
                                    <div class="text-red-500 mb-2">
                                        <img src="/Assets/images/homepage/banner/specialist-oncopathology-icon.svg"
                                            alt="" />
                                    </div>
                                    <p>Specialist<br />Oncopathology</p>
                                </div>
                            </div>

                            <!-- HEX 4 -->
                            <div class="hex-wrap">
                                <svg viewBox="0 0 200 180" class="hex-svg">
                                    <polygon points="50,5 150,5 195,90 150,175 50,175 5,90" fill="white"
                                        stroke="#e5e7eb" />
                                </svg>
                                <div class="hex-content">
                                    <div class=" mb-2">
                                        <img src="/Assets/images/homepage/banner/envisioned-icon.svg" alt="" />
                                    </div>
                                    <p> Envisioned by late<br />Dr Anita Borges </p>
                                </div>
                            </div>

                        </div>

                    </div>

                </div>
            </div>
        </div>

        <!-- ================= RIGHT ================= -->
        <div class="relative hero-right-wrap">

            <div class="pxl-banner-inner">
                <div class="box-image-main">
                    <div class="box-image-main-inner">
                        <div class="swiper heroSwiper">

                            <div class="swiper-wrapper">

                                <div class="swiper-slide">
                                    <img src="/Assets/images/homepage/banner/banner-img1.webp"
                                        class="w-full h-full object-cover hero-img" alt=""
                                        data-swiper-parallax="-20%" />
                                </div>

                                <div class="swiper-slide">
                                    <img src=/images/homepage/banner/banner-img2.webp"
                                        class="w-full h-full object-cover hero-img" alt=""
                                        data-swiper-parallax="-20%" />
                                </div>"/Assets

                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@* JOURNEY SECTION *@
<section class="section-pb journey-section relative">
    <div class="section-wrapper">

        <!-- ── LEFT: Photo + floating Doctor card ── -->
        <div class="photo-block">
            <div class="photo-img-box">
                <img src="/Assets/images/homepage/journey/journey-img.webp" alt="" />
            </div>

            <div class="journey-photo-vector floating-icon"><img src="/Assets/images/common-images/hexagon-sm-white.svg"
                    alt="" class="object-cover" /></div>
        </div>

        <!-- ── RIGHT: Heading + 3 cards ── -->
        <div class="container">
            <div class="right-block-outer">
                <div class="wrapper-title-outer sm:max-w-[32vw] 2xl:max-w-[32vw] sm:m-auto">
                    <div class="wrapper-title title-heading-outer title-heading-outer-center pb-5 sm:pb-10">
                        <h2 class="text-h2 title-heading-anim">
                            Choose Your <span class="highlight-span"> Journey </span>
                        </h2>
                        <p>Tailored pathways for every stakeholder in cancer care</p>
                    </div>
                </div>

                <div class="outer-view">
                    <div class="journey-vector floating-icon"><img
                            src="/Assets/images/common-images/hexagon-sm-white.svg" alt="" class="object-cover" /></div>
                    <div class="journey-slider relative custom-arrow-slider mt-5 ">

                        <div class="swiper journeySwiper">
                            <div class="swiper-wrapper">

                                <!-- Slide 1 -->
                                <div class="swiper-slide">
                                    <div class="journey-card">
                                        <div class="c-icon">
                                            <img src="/Assets/images/homepage/journey/doctor-icon.svg" alt="" />
                                        </div>
                                        <p class="c-label">Doctor</p>
                                        <p class="c-sub">Submit cases, order tests, access reports</p>
                                        <div class="arrow-circle">
                                            <img src="/Assets/images/common-images/arrow-black.svg" alt="" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Slide 2 -->
                                <div class="swiper-slide">
                                    <div class="journey-card data-trigger" data-trigger="modal"
                                        data-target="#copPartnerPopup">
                                        <div class="c-icon">
                                            <img src="/Assets/images/homepage/journey/lab-icon.svg" alt="" />
                                        </div>
                                        <p class="c-label">Lab / Hospital</p>
                                        <p class="c-sub">Partner with us for specialized testing</p>
                                        <div class="arrow-circle">
                                            <img src="/Assets/images/common-images/arrow-black.svg" alt="" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Slide 3 -->
                                <div class="swiper-slide">
                                    <div class="journey-card data-trigger" data-trigger="modal"
                                        data-target="#secondOpinionPopup">
                                        <div class="c-icon">
                                            <img src="/Assets/images/homepage/journey/patient-icon.svg" alt="" />
                                        </div>
                                        <p class="c-label">Patient / Caregiver</p>
                                        <p class="c-sub">Request second opinion</p>
                                        <div class="arrow-circle">
                                            <img src="/Assets/images/common-images/arrow-black.svg" alt="" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Slide 4 -->
                                <div class="swiper-slide">
                                    <div class="journey-card pointer-events-none">
                                        <div class="c-icon">
                                            <img src="/Assets/images/homepage/journey/student-icon.svg" alt="" />
                                        </div>
                                        <p class="c-label">Student / Fellow</p>
                                        <p class="c-sub">Training programs, fellowships, resources</p>
                                        @* <div class="arrow-circle">
                                                <img src="/Assets/images/common-images/arrow-black.svg" alt="" />
                                           </div> *@
                                    </div>
                                </div>



                            </div>
                        </div>

                        <!-- Arrows -->
                        <div class="swiper-button-prev custom-arrow">
                            <img src="/Assets/images/common-images/left-arrow-swiper.svg" />
                        </div>
                        <div class="swiper-button-next custom-arrow">
                            <img src="/Assets/images/common-images/right-arrow-swiper.svg" />
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
    <div class="bg-vector-journey bg-vector-wrap"><img src="/Assets/images/vector-bg-01.svg" alt="" /></div>
</section>

@* TREATMENT DECISIONS SECTION *@
