                class="px-0 md:px-6 lg:px-8 py-6 flex flex-col gap-3 card-divider items-start team-item-box reveal-item icon-transform-item">
                <div class="card-icon mb-2 icon-transform">
                    <img src="/Assets/images/homepage/treatment-decisions/onopathology-expertise.svg" class="" alt="" />
                </div>
                <h3 class="font-semibold text-20 leading-snug">
                    Onopathology<br />expertise
                </h3>
                <a class="themeht-btn color-btn arrow-btn" data-trigger="modal" data-target="#oncopathologyPopup"> Learn
