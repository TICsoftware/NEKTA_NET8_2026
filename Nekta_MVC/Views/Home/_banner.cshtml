@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model List<HomeCommonModel>


<section class="relative overflow-hidden hero-section">
    <div class="hero-grid max-h-[630px]">
        <!-- ================= LEFT ================= -->

        @foreach (var item in Model.Where(x => x.IsBlock == 0))
        {
            <div class="relative w-full overflow-hidden hero-left-outer-wrap h-[630px]">
                <div class="hero-vid-wrap">
                    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover"
                        poster="@item.Video_poster">
                        <source src="@item.Video_path" type="video/mp4">
                        <track src="@item.Video_path" kind="captions" srclang="en" label="english_captions">
                    </video>
                    <!-- 🔲 Dark Overlay (for readability) -->
                    <div class="banner-overlay-wrap"></div>
                </div>
                <div class="container">
                    <div class="relative z-10 max-w-xl herobanner-content-wrapper py-8">

                        <h1 class="text-h1-home font-medium h1-title-heading-anim">
                            @Html.Raw(item.DisplayTitle.CleanParagraphTags())
                        </h1>

                        @Html.Raw(item.Intro.CleanParagraphTags())

                        <!-- HEX GRID -->
                        <div class="flex flex-wrap gap-1 mt-4 sm:mt-8 banner-hex-wrap">

                            <!-- HEX -->
                            <div
                                class="relative z-10 flex flex-wrap md:flex-nowrap justify-center md:justify-start gap-4 herosection-hex-outer">

                                @Html.Raw(item.Content)

                            </div>

                        </div>

                    </div>
                </div>
            </div>
        }
        <!-- ================= RIGHT ================= -->
        <div class="relative hero-right-wrap">

            <div class="pxl-banner-inner">
                <div class="box-image-main">
                    <div class="box-image-main-inner">
                        <div class="swiper heroSwiper">
                            <div class="swiper-wrapper">
                                @foreach (var item in Model.Where(x => x.IsBlock == 1))
                                {
                                    <div class="swiper-slide">
                                        <img src="@item.ThumbnailImage"
                                            class="w-full h-full object-cover hero-img" alt="@item.ThumbnailAltText"
                                            data-swiper-parallax="-20%" />
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>