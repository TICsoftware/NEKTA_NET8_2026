
@model List<Core_project_BusinessLogic.Entity.TestMasterEntity>
@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
 
}


<h2>Test Master</h2>

@if (TempData["ValidationError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ValidationError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="mb-3">

    <div class="row">

        <div class="col-md-4">

            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Search Test Name" />

        </div>

        <div class="col-md-2">

            <button type="submit"
                    class="btn btn-primary">
                Search
            </button>

        </div>

    </div>

</form>
<a href="#" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">Add New</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Specimen</th>
            <th>Type</th>
            <th>Organ</th>
            <th>Dept</th>
            <th>Status</th>
            <th>Action</th>
        </tr>                                                         
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TestName</td>
                <td>@item.SpecimenName</td>
                <td>@item.TestTypeName</td>
                <td>@item.OrganName</td>
                <td>@item.DepartmentName</td>

                <td>
                    @if (item.Status == 1)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>
 
               <td>

    <!-- EDIT -->
<button class="btn btn-sm btn-primary"
        onclick="editTest(@item.TestId)">
    Edit
</button>

    <!-- STATUS BUTTON -->
    @if (item.Status == 1)
    {
        <button class="btn btn-sm btn-warning"
                onclick="changeStatus(@item.TestId,0)">
            Deactivate
        </button>
    }
    else
    {
        <button class="btn btn-sm btn-success"
                onclick="changeStatus(@item.TestId,1)">
            Activate
        </button>
    }

</td>
            </tr>
        }
    </tbody>
</table>
@{
    int totalPages =
        (int)Math.Ceiling(
            (double)ViewBag.TotalRecords
            / ViewBag.PageSize
        );
}

<nav>

    <ul class="pagination">

        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item
                @(ViewBag.Page == i ? "active" : "")">

                <a class="page-link"
                   href="@Url.Action(
                        "Index",
                        new {
                            page = i,
                            search = ViewBag.Search
                        })">

                    @i

                </a>

            </li>
        }

    </ul>

</nav>
<div class="modal fade" id="addModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Test Master</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <form method="post" asp-action="Save" id="testMasterForm" novalidate>

                <div class="modal-body">

                    <!-- HIDDEN ID -->
                    <input type="hidden" id="TestId" name="TestId" />

                    <div class="mb-3">
                        <label class="form-label" for="NABL_Option">NABL Option <span class="text-danger">*</span></label>
                        <select name="NABL_Option" id="NABL_Option" class="form-select">
                            <option value="">Select NABL Option</option>
                            @foreach (var nabl in ViewBag.NABL_Option)
                            {
                                <option value="@nabl.ID">@nabl.Name</option>
                            }
                        </select>
                        <span id="NABL_OptionError" class="text-danger d-none"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="TestName">Test Name <span class="text-danger">*</span></label>
                        <input type="text" id="TestName" name="TestName" maxlength="200" class="form-control" />
                        <span id="TestNameError" class="text-danger d-none"></span>
                    </div>

                    <p class="text-muted small mb-2">Select at least one master type <span class="text-danger">*</span></p>

                    <!-- SPECIMEN -->
                    <div class="mb-3">
                        <label>Specimen</label>

                    <select name="SpecimenId"
        id="SpecimenId"
        class="form-select">

    <option value="">Select Specimen</option>

    @if (ViewBag.Specimen != null)
    {
        foreach (var item in ViewBag.Specimen)
        {
            <option value="@item.ID">
                @item.Name
            </option>
        }
    }

</select>
                    </div>

                    <!-- TEST TYPE -->
                    <div class="mb-3">
                        <label>Test Type</label>

                     <select name="TestTypeId"
        id="TestTypeId"
        class="form-select">

    <option value="">Select Test Type</option>

    @if (ViewBag.TestType != null)
    {
        foreach (var item in ViewBag.TestType)
        {
            <option value="@item.ID">
                @item.Name
            </option>
        }
    }

</select>
                    </div>

                    <!-- ORGAN -->
                    <div class="mb-3">
                        <label>Organ</label>

                     <select name="OrganId"
        id="OrganId"
        class="form-select">

    <option value="">Select Organ</option>

    @if (ViewBag.Organ != null)
    {
        foreach (var item in ViewBag.Organ)
        {
            <option value="@item.ID">
                @item.Name
            </option>
        }
    }

</select>
                    </div>

                    <!-- DEPARTMENT -->
                    <div class="mb-3">
                        <label>Department</label>

                      <select name="DepartmentId"
        id="DepartmentId"
        class="form-select">

    <option value="">Select Department</option>

    @if (ViewBag.Department != null)
    {
        foreach (var item in ViewBag.Department)
        {
            <option value="@item.ID">
                @item.Name
            </option>
        }
    }

</select>
                        <span id="MasterTypeError" class="text-danger d-none"></span>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!--  CUSTOM JS -->
<script src="~/js/NABL_testmaster.js"></script>
