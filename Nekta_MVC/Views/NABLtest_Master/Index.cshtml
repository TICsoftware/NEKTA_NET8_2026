@model Core_project_BusinessLogic.Entity.MasterEntity
@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    var list = ViewBag.List as List<Core_project_BusinessLogic.Entity.MasterEntity>;
}

<!-- 🔥 IMPORTANT: Add this wrapper instead of <body> -->
<div data-master-type="@Model.MasterType">

<link href="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.css" rel="stylesheet" />

<style>
    .drag-handle { cursor: move; }
    .inactive-row { background-color: #f8d7da; }
</style>

<div class="page-heading">

    <h4>NABL Test Master - @Model.MasterType</h4>
<form method="get">

    <!-- IMPORTANT -->
    <input type="hidden"
           name="type"
           value="@Model.MasterType" />

    <div class="row">

        <div class="col-md-10">

            <input type="text"
                   name="search"
                   value="@Model.SearchText"
                   class="form-control"
                   placeholder="Search name..." />

        </div>

        <div class="col-md-2">

            <button type="submit"
                    class="btn btn-success w-100">
                Search
            </button>

        </div>

    </div>

</form>
    <!-- 🔄 TABS -->
    @{
        string[] types = { "Specimen", "TestType", "Organ", "Department" };
    }
    <div class="mb-3">
        @foreach (var t in types)
        {
            <a href="@Url.Action("Index", new { type = t })"
               class="btn @(Model.MasterType == t ? "btn-primary" : "btn-outline-primary")">
                @t
            </a>
        }
    </div>

    <!-- ➕ ADD BUTTON -->
    <button class="btn btn-success mb-3" onclick="openModal()">+ Add New</button>

    <!-- 📋 TABLE -->
    <table class="table table-bordered">
        <thead>
            <tr>
                <th style="width:50px;"></th>
                <th>Name</th>
                <th>Sequence</th>
                <th>Status</th>
                <th style="width:150px;">Action</th>
            </tr>
        </thead>

        <tbody id="sortable">

            @if (list != null && list.Count > 0)
            {
                foreach (var item in list)
                {
                    <tr data-id="@item.ID" class="@(item.Status == 0 ? "inactive-row" : "")">

                        <td class="drag-handle">☰</td>

                        <!-- NAME -->
                        <td>
                            <span id="lbl_@item.ID">@item.Name</span>
                            <input type="text" value="@item.Name"
                                   class="form-control d-none"
                                   id="txt_@item.ID"
                                   maxlength="200" />
                        </td>

                        <!-- SEQUENCE -->
                        <td>
                            <span id="lblseq_@item.ID">@item.Sequence</span>
                            <input type="number" value="@item.Sequence"
                                   class="form-control d-none"
                                   id="txtseq_@item.ID"
                                   min="1" max="9999" />
                        </td>

                        <!-- STATUS -->
                        <td>
                            @if ((item.Status ?? 1) == 1)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>

                        <!-- ACTION -->
                        <td>
                            <button class="btn btn-sm btn-primary edit-btn" data-id="@item.ID">Edit</button>

                            <button class="btn btn-sm btn-success save-btn d-none" data-id="@item.ID">Save</button>

                            @if ((item.Status ?? 1) == 1)
                            {
                                <button class="btn btn-sm btn-warning deactivate-btn" data-id="@item.ID">
                                    Deactivate
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success activate-btn" data-id="@item.ID">
                                    Activate
                                </button>
                            }
                        </td>

                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5">No records found</td></tr>
            }

        </tbody>
    </table>


    @{
    int totalPages = (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize);
}

<div class="mt-3">
    @for (int i = 1; i <= totalPages; i++)
    {
        <a href="@Url.Action("Index", new {
            type = Model.MasterType,
            search = Model.SearchText,
            page = i
        })"
           class="btn btn-sm @(i == Model.PageNumber ? "btn-primary" : "btn-outline-primary")">
            @i
        </a>
    }
</div>
</div>

<!--  ADD MODAL -->
<div class="modal fade" id="addModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Add @Model.MasterType</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="addMasterForm" novalidate>
                <div class="modal-body">
                    <label class="form-label" for="newName">Name <span class="text-danger">*</span></label>
                    <input type="text" id="newName" name="Name" maxlength="200" placeholder="Name" class="form-control mb-1" />
                    <span id="newNameError" class="text-danger d-none"></span>

                    <label class="form-label mt-2" for="newSeq">Sequence <span class="text-danger">*</span></label>
                    <input type="number" id="newSeq" name="Sequence" min="1" max="9999" placeholder="Sequence" class="form-control mb-1" />
                    <span id="newSeqError" class="text-danger d-none"></span>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-success" onclick="saveNew()">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

</div> <!--  END wrapper -->

<!-- ✅ REQUIRED SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

@section Scripts {
    <script src="~/js/nabl_master.js"></script>
}