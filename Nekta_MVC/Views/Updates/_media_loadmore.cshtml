@model List<Nekta_BusinessLogic.Entity.Common_List>

@foreach (var item in Model)
{
    <!-- Card -->
    <div
        class="bg-white dark-bgblack rounded-2xl shadow-lg px-3 sm:px-4 pt-6 pb-6 relative drop-shadow-custom grid-item-inner group cursor-pointer grid-item-box media-list-item">
        <a href="@item.Url" class="stretched-link" target="@item.Url_target"></a>
        <div class="grid-img-wrap rounded-lg overflow-hidden relative aspect-390/220">

            <img src="@item.Thumbnail_img" alt="@item.Thumbnail_img_alt_text"
                class="rounded-lg w-full h-full object-cover block transition-transform duration-700 ease-out will-change-transform group-hover:scale-105">

            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent">
            </div>

        </div>

        <!-- Content -->
        <div class="grid-info flex flex-col gap-y-2 pt-4">

            <div class="flex items-center justify-between gap-4">

                <!-- Title -->
                <div class="max-w-[85%] transition-all duration-300 hover:text-[#DE392E]">

                    <h3 class="grid-heading">
                        @item.ContTitle
                    </h3>

                </div>

                <!-- Arrow -->

                <div
                    class="group min-w-[32px] w-[32px] h-[32px] rounded-full border border-[#DE392E] flex items-center justify-center transition-all duration-300 hover:bg-[#DE392E] circle-arrow-btn">

                    <img src="/Assets/images/common-images/btn-arrow-red.svg" alt="Arrow"
                        class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-[3px] ">

                </div>

            </div>


        </div>

    </div>
}