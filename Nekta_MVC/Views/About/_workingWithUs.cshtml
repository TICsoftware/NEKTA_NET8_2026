@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model List<AboutCommonModel>


@{
    var Component = Model
    .Where(x => x.IsBlock == 0)
    .OrderBy(x => x.Sequence)
    .FirstOrDefault();
}



<section class="relative section-spacing lg:h-[1050px] whatgain-section overflow-hidden">
    <div class="whatgain-bg bg-parallax overflow-hidden">
        <img src="/Assets/images/careers/careers-bg.webp" alt=""
            class="w-full h-full object-cover dark-grayscaleinvert0" />
    </div>
    <div class="container">
        <div class="wrapper-title-outer wrapper-title-outer-center">
            <div
                class="wrapper-title title-heading-outer title-heading-outer-center pb-5 sm:pb-10 filldark-title-heading-anim">
                <h2 class="text-h2 title-heading-anim title-heading-anim-white ">
                    @Html.Raw(Component.DisplayTitle.CleanParagraphTags())
                </h2>
            </div>
        </div>

        <div class="whatgain-slider relative custom-arrow-slider mt-5 sm:mt-10">
            <div class="swiper whatgainSwiper">
                <div class="swiper-wrapper">
                    @foreach (var item in Model
                                        .Where(x => x.IsBlock == 1)
                                        .OrderBy(x => x.Sequence))
                    {
                        <div class="swiper-slide">
                            <div class="careers-gain-card">
                                <div class="gain-card-img aspect-390/300">
                                    <img src="@item.ThumbnailImage" alt="@item.ThumbnailAltText">
                                </div>
                                <div class="gain-card-content">
                                    <h3 class="text-20">@item.Title</h3>
                                    <p>
                                        @Html.Raw(item.Intro.CleanParagraphTags())
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>

            <!-- Arrows -->
            <div class="swiper-button-prev custom-arrow">
                <img src="/Assets/images/common-images/left-arrow-swiper.svg" />
            </div>
            <div class="swiper-button-next custom-arrow">
                <img src="/Assets/images/common-images/right-arrow-swiper.svg" />
            </div>
        </div>


    </div>
</section>