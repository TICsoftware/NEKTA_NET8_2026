@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model List<AboutCommonModel>


@{
    var Component = Model
    .Where(x => x.IsBlock == 0)
    .OrderBy(x => x.Sequence)
    .FirstOrDefault();
}


<section class="relative section-pb">
    <div class="container">
        <div class="wrapper-title-outer wrapper-title-outer-center">
            <div class="wrapper-title title-heading-outer title-heading-outer-center pb-5 sm:pb-10">
                <h2 class="text-h2 title-heading-anim">
                    @Html.Raw(Component.DisplayTitle.CleanParagraphTags())
                </h2>
            </div>
        </div>
        <div class="marquee mt-5">
            <div class="marquee-track">
                @foreach (var item in Model
                                .Where(x => x.IsBlock == 1)
                                .OrderBy(x => x.Sequence))
                {
                    <div class="marquee-item aspect-305/235">
                        <div class="marquee-text">@item.Title</div>
                    </div>
                }
            </div>
        </div>
        
        @if (!string.IsNullOrWhiteSpace(Component.Url))
        {
            <div class="text-center mt-4 sm:mt-8">
                <a href="@Component.Url" class="themeht-btn color-btn">
                    @Component.Url_Text
                </a>
            </div>
        }
    </div>
</section>