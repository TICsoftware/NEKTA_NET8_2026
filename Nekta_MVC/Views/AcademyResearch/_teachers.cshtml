@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model CommonViewModel

<div
    class="feature-item flex flex-col lg:flex-row gap-6 sm:gap-10 md:gap-10 xl:gap-10 2xl:gap-14 items-center relative mb-15 sm:mb-30 lg:mb-30 last:mb-0 animate-viewport text-secondary-wrapper">

    <!-- Image -->
    <div
        class="w-full lg:w-3/5 flex flex-col lg:flex-row justify-between items-start gap-y-2 lg:gap-y-0 lg:gap-x-6 2xl:gap-x-10">
        <div class="rounded-2xl overflow-hidden relative z-1">
            <img src="@Model.ThumbnailImage" alt="@Model.ThumbnailImageAlt"
                class="w-full h-full object-cover rounded-2xl">
        </div>
    </div>

    <!-- Content -->
    <div class="w-full lg:w-2/5 lg:mt-0 2xl:mt-0">
        <div class="wrapper-title-outer">
            <div
                class="wrapper-title title-heading-outer title-heading-outer-start pb-5 sm:pb-5 no-titlepadding-wrapper">
                <h2 class="text-h2 title-heading-anim px-0">
                    @Html.Raw(Model.Intro.CleanParagraphTags())
                </h2>
            </div>
        </div>

        <div class="flex flex-col">
            @Html.Raw(Model.Content)
        </div>

    </div>

</div>