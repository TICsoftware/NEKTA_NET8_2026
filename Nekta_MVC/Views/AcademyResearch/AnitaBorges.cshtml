@using Nekta_MVC.Helpers
@model Nekta_BusinessLogic.Entity.AcademyResearchModel
@{
    ViewData["Title"] = "Our Team";
}


@section head {
    <title>@Model.AR_Content.cont_window_title</title>

    <meta content="@Model.AR_Content.cont_metatag" name="keywords" />
    <meta content="@Model.AR_Content.cont_metadesc" name="description" />


    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="" />
    <meta name="twitter:title" content="@Model.AR_Content.ContTitle" />
    <meta name="twitter:description" content="@Model.AR_Content.cont_metadesc" />

    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Centre for Oncopathology" />
    <meta property="og:title" content="@Model.AR_Content.ContTitle" />
    <meta property="og:description" content="@Model.AR_Content.cont_metadesc" />
    <meta property="og:url" content="https://www.oncopath.org/" />
    <meta property="og:image" content="@Model.AR_Content.cont_meta_image" />

    <meta itemprop="name" content="Centre for Oncopathology" />
    <meta itemprop="description" content="@Model.AR_Content.cont_metadesc" />
    <meta itemprop="image" content="@Model.AR_Content.cont_meta_image" />

    <!-- Facebook / Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Centre for Oncopathology" />
    <meta property="og:title" content="@Model.AR_Content.ContTitle" />
    <meta property="og:description" content="@Model.AR_Content.cont_metadesc" />
    <meta property="og:image" content="@Model.AR_Content.cont_meta_image" />
    <meta property="og:url" content="https://www.oncopath.org/" />

    <link rel="canonical" href="@Model.AR_Content.CanonicalUrl" />
}
@section Styles {
    <link rel="stylesheet" href="~/Assets/css/innerbanner-style.css" />
    <link rel="stylesheet" href="~/Assets/css/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/Assets/css/swiper-custom.css" />
    <link rel="stylesheet" href="~/Assets/css/dranitaborges-style.css" />
}




<section class="banner-inner-section mt-[99px] lg:mt-[153px] h-full relative">
    <picture class="bannerinner-picture relative block w-full h-full">
        <source media="(min-width:992px)" srcset="@Model.AR_Content.MastheadImage" />
        <source media="(max-width:991px)" srcset="@Model.AR_Content.MobileMastheadImage" />
        <img alt="" class="object-cover" src="@Model.AR_Content.MastheadImage" />
    </picture>


    <div class="banner-inner-outer relative w-full h-full">
        <div class="inner-banner-vector">
            <img src="/Assets/images/inner-banner-vector.svg" alt="" class="banner-vector-img" />
            <div class="banner-mask">
                <img src="/Assets/images/abstract-elements-banner.webp" class="masked-img" />
            </div>
            <div
                class="absolute top-[15%] md:top-[30%] left-0 w-full px-0 md:px-8 xl:px-6 2xl:px-8 inner-banner-caption">
                <div class="container">
                    <nav aria-label="breadcrumb" class="breadcrumb_container pb-2 lg:pb-0 mb-2">
                        @Html.Raw(Model.AR_Content.BreadcrumPath)
                    </nav>
                    <div class="w-full sm:max-w-[60vw] lg:max-w-[35vw] innerbanner-title-outer">

                        <h1 class="text-h1 innerbanner-title-heading ">
                            @Html.Raw(Model.AR_Content?.Cont_hmpg_intro.CleanParagraphTags())</h1>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


<div class="relative">

    <div class="bg-wrapper-flat"></div>

    @foreach (var item in Model.AnitaBorgesList)
    {
        @await Html.PartialAsync("_anita_borges", item)
    }
</div>



<section class="relative section-pt">
    <div class="left-float-vector floating-icon">
        <img src="/Assets/images/hexagon-vector-shape.svg" class="object-cover dark-grayscaleinvert" alt="">
    </div>

    <div class="container">

        @foreach (var item in Model.OpinionList)
        {
            <div
                class="feature-item flex flex-col lg:flex-row-reverse gap-6 sm:gap-10 md:gap-10 xl:gap-10 2xl:gap-14 items-center relative mb-15 sm:mb-30 lg:mb-30 last:mb-0 animate-viewport text-secondary-wrapper">

                <!-- Image -->
                <div
                    class="w-full lg:w-3/5 flex flex-col lg:flex-row-reverse justify-between items-start gap-y-2 lg:gap-y-0 lg:gap-x-6 2xl:gap-x-10">
                    <div class="rounded-2xl overflow-hidden relative z-1">
                        <img src="@item.ThumbnailImage" alt="@item.ThumbnailImageAlt"
                            class="w-full h-full object-cover rounded-2xl">
                    </div>
                </div>

                <!-- Content -->
                <div class="w-full lg:w-2/5 lg:mt-0 2xl:mt-0">
                    <div class="wrapper-title-outer">
                        <div
                            class="wrapper-title title-heading-outer title-heading-outer-start pb-5 sm:pb-5 no-titlepadding-wrapper">
                            <h2 class="text-h2 title-heading-anim px-0">
                                @Html.Raw(item.Intro.CleanParagraphTags())
                            </h2>
                        </div>
                    </div>

                    <div class="flex flex-col">
                        @Html.Raw(item.Content)
                    </div>

                </div>

            </div>

        }
        @foreach (var item in Model.TeacherAlwaysList)
        {
            <div
                class="feature-item flex flex-col lg:flex-row gap-6 sm:gap-10 md:gap-10 xl:gap-10 2xl:gap-14 items-center relative mb-15 sm:mb-30 lg:mb-30 last:mb-0 animate-viewport text-secondary-wrapper">

                <!-- Image -->
                <div
                    class="w-full lg:w-3/5 flex flex-col lg:flex-row justify-between items-start gap-y-2 lg:gap-y-0 lg:gap-x-6 2xl:gap-x-10">
                    <div class="rounded-2xl overflow-hidden relative z-1">
                        <img src="@item.ThumbnailImage" alt="@item.ThumbnailImageAlt"
                            class="w-full h-full object-cover rounded-2xl">
                    </div>
                </div>

                <!-- Content -->
                <div class="w-full lg:w-2/5 lg:mt-0 2xl:mt-0">
                    <div class="wrapper-title-outer">
                        <div
                            class="wrapper-title title-heading-outer title-heading-outer-start pb-5 sm:pb-5 no-titlepadding-wrapper">
                            <h2 class="text-h2 title-heading-anim px-0">
                                @Html.Raw(item.Intro.CleanParagraphTags())
                            </h2>
                        </div>
                    </div>

                    <div class="flex flex-col">
                        @Html.Raw(item.Content)
                    </div>

                </div>

            </div>
        }

    </div>
    <div class="right-float-vector floating-icon">
        <img src="/Assets/images/hexagon-vector-shape.svg" class="object-cover dark-grayscaleinvert" alt="">
    </div>
</section>


<div class="relative">

    <section class="relative section-pt mentorshipmoments-section" id="mentorship-moments">
        <div class="container">
            @{
                var header = Model.MentorshipMomentsList.FirstOrDefault(x => x.IsBlock == 0);
            }
            @if (header != null)
            {
                <div class="wrapper-title-outer max-w-4xl mx-auto">
                    <div class="wrapper-title title-heading-outer title-heading-outer-center pb-5 sm:pb-10">

                        <h2 class="text-h2 title-heading-anim mb-3">
                            @Html.Raw(header.DisplayTitle?.CleanParagraphTags())
                        </h2>

                        <h3 class="dark-textwhite">
                            @Html.Raw(header.Intro?.CleanParagraphTags())
                        </h3> @Html.Raw(header.Content)

                    </div>
                </div>
            }



            <div class="relative">

                <div class="mentorshipmoments-grid mentorshipmoments-slider custom-arrow-slider">
                    <div class="swiper mentorshipmomentsSwiper">
                        <div class="swiper-wrapper">
                            @foreach (var item in Model.MentorshipMomentsList.Where(x => x.IsBlock == 1))
                            {
                                @await Html.PartialAsync("_ mentorship", item)
                            }
                        </div>
                    </div>

                    <!-- Arrows -->
                    <div class="swiper-button-prev custom-arrow">
                        <img src="/Assets/images/common-images/left-arrow-swiper.svg" />
                    </div>
                    <div class="swiper-button-next custom-arrow">
                        <img src="/Assets/images/common-images/right-arrow-swiper.svg" />
                    </div>
                </div>

                <div class="text-center mt-8 sm:mt-12">
                    <a href="https://www.youtube.com/playlist?list=PLDfHp88q6kYjQgL0dm_2NOBPEPsO4G5sx" target="_blank"
                        class="themeht-btn color-btn darkwhite-btn">
                        More
                    </a>
                </div>

                <div class="tq-line-vector">
                    <svg viewBox="0 0 1600 200" class="line-svg">
                        <path id="linePath02" class="linePath"
                            d="M1622.69 144.935C1554.29 136.911 1356.6 107.321 1210.29 48.1162C1159.38 27.5151 1150.64 8.39514 1096.14 1.56632C1002.98 -10.1083 809.246 77.186 721.854 111.525C550.817 178.732 258.93 237.94 -35.746 53.6113"
                            fill="none" stroke="#DE392E" stroke-width="1.00225" />

                        <circle class="dot dot1" r="6" cx="0" cy="0" fill="#DE392E"></circle>
                        <circle class="dot dot2" r="6" cx="0" cy="0" fill="#DE392E"></circle>

                    </svg>
                </div>

            </div>



        </div>
    </section>


    <div class="bg-team-vector bg-vector-wrap"><img src="/Assets/images/bottom-vector-bg.svg" alt="" /></div>

    @foreach (var item in Model.LegacyList)
    {
        <section class="relative section-spacing legacyintegrity-section">
            <div class="container">
                <div class="wrapper-title-outer max-w-4xl mx-auto">
                    <div class="wrapper-title title-heading-outer title-heading-outer-center">
                        <h2 class="text-h2 title-heading-anim mb-3">
                            @Html.Raw(item.Intro.CleanParagraphTags())</h2> @Html.Raw(item.Content)
                    </div>
                </div>
            </div>
        </section>
    }

</div>

<div id="videoModal" class="fixed inset-0 z-[999] hidden">

    <!-- BACKDROP -->
    <div class="modal-bg absolute inset-0 bg-black/60 backdrop-blur-md"></div>

    <!-- VIDEO BOX -->
    <div id="videoBox" class="absolute bg-black rounded-full overflow-hidden shadow-2xl">

        <!-- CLOSE -->
        <button id="closeVideo" class="absolute top-3 right-3 z-10 text-white text-xl">✕</button>

        <!-- MP4 -->
        <video id="mp4Video" class="w-full h-full hidden object-cover" controls></video>

        <!-- YOUTUBE -->
        <iframe id="youtubeVideo" class="w-full h-full hidden" frameborder="0" allow="autoplay; encrypted-media"
            allowfullscreen>
        </iframe>

    </div>
</div>

@section Scripts {
    <script src="~/Assets/js/innerbanner-script.js"></script>
    <script src="~/Assets/js/swiper-bundle.min.js"></script>
    <script src="~/Assets/js/video-popup-script.js"></script>
    <script src="~/Assets/js/dranitaborges-script.js"></script>

    <script>
        $(document).ready(function () {

            var hash = window.location.hash;

            if (hash === "#mentorship-moments") {

                var el = document.getElementById("mentorship-moments");

                if (el) {
                    el.scrollIntoView({ behavior: "smooth" });
                }
            }
        });
    </script>
}