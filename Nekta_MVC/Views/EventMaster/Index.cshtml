@using Core_project_BusinessLogic.Entity
@model EventMasterVM

@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
}

<h2>Event Master</h2>

<!-- 🔍 SEARCH -->
<form method="get">
    <input type="text" name="search" value="@Model.SearchText" placeholder="Search title..." />
    <button type="submit" class="btn btn-success">Search</button>
</form>

<br />

<!-- ➕ ADD -->
<button class="btn btn-primary" onclick="openModal()">Add New</button>

<br /><br />

<!-- 📋 LIST -->
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Type</th>
            <th>Mode</th>
            <th>Date</th>
            <th>Status</th>
            <th style="width:180px;">Action</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.List != null && Model.List.Count > 0)
        {
            foreach (var item in Model.List)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.EventTypeName</td>
                    <td>@item.EventModeName</td>
                    <td>@item.EventDate?.ToString("dd MMM yyyy")</td>

                    <td>
                        @if (item.Status == 1)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
<td>
                    <a href="/EventMaster/Edit/@item.EventId"
                       class="btn btn-sm btn-primary">Edit</a>
              

                        @if (item.Status == 1)
                        {
                            <button class="btn btn-sm btn-danger"
                                    onclick="changeStatus(@item.EventId,0)">
                                Deactivate
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-success"
                                    onclick="changeStatus(@item.EventId,1)">
                                Activate
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6">No records found</td>
            </tr>
        }
    </tbody>
</table>
@{
    int totalPages = (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize);
}

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">

            <!-- 🔹 PREVIOUS -->
            @if (Model.PageNumber > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           page = Model.PageNumber - 1,
                           search = Model.SearchText
                       })">
                        Previous
                    </a>
                </li>
            }

            <!-- 🔢 PAGE NUMBERS -->
            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == Model.PageNumber)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               page = i,
                               search = Model.SearchText
                           })">
                            @i
                        </a>
                    </li>
                }
            }

            <!-- 🔹 NEXT -->
            @if (Model.PageNumber < totalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           page = Model.PageNumber + 1,
                           search = Model.SearchText
                       })">
                        Next
                    </a>
                </li>
            }

        </ul>
    </nav>
}

<!-- ========================= -->
<!-- 🔥 MODAL -->
<!-- ========================= -->

<div class="modal fade" id="eventModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Event Master</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- ✅ SINGLE FORM -->
            <form method="post" id="eventForm" action="/EventMaster/Save" novalidate>

                <div class="modal-body">

                    @Html.ValidationSummary(false, "", new { @class = "text-danger mb-2" })

                    <input type="hidden" id="EventId" name="EventId" value="@Model.Current?.EventId" />

                    <!-- TITLE -->
                    <label class="form-label">Title <span class="text-danger">*</span></label>
                    <input type="text" id="Title" name="Title" class="form-control mb-1"
                           value="@Model.Current?.Title"
                           placeholder="Title" />
                    @Html.ValidationMessage("Title", "", new { @class = "text-danger d-block mb-2" })

                    <!-- TYPE -->
                    <label class="form-label">Event Type <span class="text-danger">*</span></label>
<select id="EventTypeId" name="EventTypeId" class="form-control mb-1">
    <option value="">Select Type</option>

    @foreach (var t in ViewBag.EventType)
    {
        if (Model.Current != null && Model.Current.EventTypeId == t.ID)
        {
            <option value="@t.ID" selected="selected">@t.Name</option>
        }
        else
        {
            <option value="@t.ID">@t.Name</option>
        }
    }
</select>
                    @Html.ValidationMessage("EventTypeId", "", new { @class = "text-danger d-block mb-2" })

                    <!-- MODE -->
                    <label class="form-label">Event Mode <span class="text-danger">*</span></label>
            <select id="EventModeId" name="EventModeId" class="form-control mb-1">
    <option value="">Select Mode</option>

    @foreach (var m in ViewBag.EventMode)
    {
        if (Model.Current != null && Model.Current.EventModeId == m.ID)
        {
            <option value="@m.ID" selected="selected">@m.Name</option>
        }
        else
        {
            <option value="@m.ID">@m.Name</option>
        }
    }
</select>
                    @Html.ValidationMessage("EventModeId", "", new { @class = "text-danger d-block mb-2" })

                    <!-- DATE -->
                    <label class="form-label">Event Date <span class="text-danger">*</span></label>
                    <input type="date" id="EventDate" name="EventDate"
                           class="form-control mb-1"
                           value="@Model.Current?.EventDate?.ToString("yyyy-MM-dd")" />
                    @Html.ValidationMessage("EventDate", "", new { @class = "text-danger d-block mb-2" })

                    <!-- TIME -->
                    <label class="form-label">Time</label>
                    <input type="text" id="EventTime" name="EventTime" class="form-control mb-1"
                           value="@Model.Current?.EventTime"
                           placeholder="Time" />
                    @Html.ValidationMessage("EventTime", "", new { @class = "text-danger d-block mb-2" })

                    <!-- SPEAKERS -->
                    <label class="form-label">Speakers</label>
                    <input type="text" id="Speakers" name="Speakers" class="form-control mb-1"
                           value="@Model.Current?.Speakers"
                           placeholder="Speakers" />
                    @Html.ValidationMessage("Speakers", "", new { @class = "text-danger d-block mb-2" })

                    <!-- CKEDITOR -->
                    <label class="form-label">Intro <span class="text-danger">*</span></label>
                    <textarea name="Intro" id="Intro" class="editor-full">
                        @Html.Raw(Model.Current?.Intro)
                    </textarea>
                    @Html.ValidationMessage("Intro", "", new { @class = "text-danger d-block mb-2" })

                    <label class="form-label mt-2">Content</label>
                    <textarea name="Content" id="Content" class="editor-full">
                        @Html.Raw(Model.Current?.Content)
                    </textarea>
                    @Html.ValidationMessage("Content", "", new { @class = "text-danger d-block mb-2" })

                    <!-- VIDEO -->
                    <label class="form-label mt-2">Video URL</label>
                    <input type="url" id="VideoUrl" name="VideoUrl" class="form-control mb-1"
                           value="@Model.Current?.VideoUrl"
                           placeholder="https://..." />
                    @Html.ValidationMessage("VideoUrl", "", new { @class = "text-danger d-block mb-2" })

                    <!-- FILE -->
                   <div class="form-group mb-3">

    <label class="form-label">
        Upload Resource 
        <span class="text-muted small">(Max 5MB)</span>
    </label>

    <!-- 🔘 BUTTON -->
    <button type="button" id="btnFile"
            class="btn btn-outline-primary d-block mb-2">
        Select File
    </button>

    <!-- 🔒 HIDDEN FILE INPUT -->
    <input type="file" id="fileInput" style="display:none;" />

    <!-- 🔒 HIDDEN PATH (MODEL BINDING) -->
    <input type="hidden" name="FilePath" id="FilePath"
           value="@Model.Current?.FilePath" />

    <!-- 📄 PREVIEW -->
    <div id="filePreview" style="display:@(string.IsNullOrEmpty(Model.Current?.FilePath) ? "none" : "block")">

        <a id="fileLink"
           href="@Model.Current?.FilePath"
           target="_blank"
           class="btn btn-sm btn-info">
            View File
        </a>

        <!-- ❌ REMOVE -->
        <button type="button"
                id="removeFile"
                class="btn btn-sm btn-danger">
            Remove
        </button>

    </div>

</div>


<hr />

<div class="form-check mb-3">
    <input type="checkbox"
           id="IsRecurring"
           name="IsRecurring"
           value="true"
           class="form-check-input"
           @(Model.Current?.IsRecurring == true ? "checked" : "") />

    <label class="form-check-label">
        Recurring Event
    </label>
</div>

<div id="recurringSection">

    <label>No. Of Days To Recur</label>

    <input type="number"
           id="RecurringAfterDays"
           name="RecurringAfterDays"
           class="form-control"
           value="@Model.Current?.RecurringAfterDays" />

    <br />

    <label>Recurring End Date</label>

    <input type="date"
           id="RecurringEndDate"
           name="RecurringEndDate"
           class="form-control"
           value="@Model.Current?.RecurringEndDate?.ToString("yyyy-MM-dd")" />

</div>


                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ========================= -->
<!-- 🔥 JAVASCRIPT -->
<!-- ========================= -->
@if ((Model.Current != null && Model.Current.EventId > 0) || !ViewData.ModelState.IsValid)
{
    <script>
        window.onload = function () {
            new bootstrap.Modal(document.getElementById('eventModal')).show();
        };
    </script>
}
<link rel="stylesheet" href="/Assets/ckeditor5/ckeditor5.css" /> 
 <script type="importmap">
{
    "imports": {
        "ckeditor5": "@Url.Content("~/Assets/ckeditor5/ckeditor5.js")",
        "ckeditor5/": "@Url.Content("~/Assets/ckeditor5/")"
    }
}
</script>

<script type="module" src="~/Assets/scripts/add_ck_editor.js"></script>
  <link rel="stylesheet" href="~/Assets/css/media-manager.css" />
    <script src="~/Assets/scripts/media-manager.js"></script>

@section Scripts {
    <script src="~/js/event_master.js"></script>
}
