@using Core_project_BusinessLogic.Entity

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/Assets/css/component_card.css">
<link rel="stylesheet" href="~/Assets/ckeditor5/ckeditor5.css" />

@{
    var fields = ViewBag.Fields as List<ComponentFieldDefinition> ?? new();
    var template = ViewBag.Template as ComponentTemplate ?? new ComponentTemplate();
    var reference = ViewBag.Reference;
    var compId = ViewBag.compId;
}

<form asp-action="SaveOurStory" method="post">
    <div class="container parent-section">

        <!-- Template Title -->
        <div class="child-label">
            @template.TemplateName
        </div>

        <!-- Dynamic Fields -->
        <partial name="_Dynamic_componentsFields" model="fields" />


        <hr />

        <!-- Block Section -->
        <div class="child-label"></div>


        <div id="counterContainer" class="accordion">

            @* @for (int i = 0; i < Model.CounterCards.Count; i++)
            {
                <partial name="_CounterCardPartial" for="CounterCards[i]" />
            } *@

        </div>


        <button type="button" id="addCounter" class="btn btn-primary mt-2">
            + Add Block
        </button>

        <button type="submit" class="btn btn-success mt-3">
            Save
        </button>

    </div>

       <input type="hidden" value="@ViewBag.compId" id="hdncompId"/> 
</form>

@section Scripts {

    <script type="importmap">
    {
        "imports": {
            "ckeditor5": "@Url.Content("~/Assets/ckeditor5/ckeditor5.js")",
            "ckeditor5/": "@Url.Content("~/Assets/ckeditor5/")"
        }
    }
    </script>

    <script type="module" src="~/Assets/scripts/add_ck_editor.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <script src="~/Assets/scripts/Component_card.js"></script>
}